# FrameTrain Environment Configuration
# Copy this file to .env.local and fill in your actual values

# ============================================
# DATABASE
# ============================================
# For local development: Use your Supabase PostgreSQL connection string
# Get it from: https://supabase.com → Project Settings → Database → Connection String
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.xxx.supabase.co:5432/postgres"

# ============================================
# JWT SECRET (Authentication)
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Salt für API-Key-Hashes (src/lib/api-key.ts) – ohne diese Variable startet
# das API-Key-Hashing nicht. Generieren z.B. mit: openssl rand -hex 32
API_KEY_SALT="dein-api-key-salt"

# ============================================
# STRIPE (Payment)
# ============================================
# Get these from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price-IDs für die beiden Abo-Pläne (Stripe Dashboard → Products)
STRIPE_PRICE_ID_MONTHLY="price_..."
STRIPE_PRICE_ID_YEARLY="price_..."

# ============================================
# API CONFIGURATION
# ============================================
API_URL="http://localhost:5001"
NEXT_PUBLIC_API_URL="http://localhost:5001"
# Basis-URL der Website selbst (für OAuth-Redirects, SSO-Callbacks etc.)
NEXT_PUBLIC_URL="http://localhost:5001"
# Kanonische Site-URL für SEO (Canonicals, hreflang, og:url, Sitemap, robots.txt).
# Fällt ohne diese Variable auf https://frame-train.com zurück.
NEXT_PUBLIC_SITE_URL="https://frame-train.com"

# ============================================
# APP DOWNLOAD
# ============================================
APP_DOWNLOAD_BASE_URL="https://github.com/FrameSphere/FrameTrain-App/releases/latest/download"

# ============================================
# GITHUB (OAuth-Login + Desktop App Downloads)
# ============================================
# OAuth-App: https://github.com/settings/developers
GITHUB_CLIENT_ID="dein-github-oauth-client-id"
GITHUB_CLIENT_SECRET="dein-github-oauth-client-secret"
# Your GitHub username/organization (für Release-Downloads)
GITHUB_OWNER="FrameSphere"
# Your repository name
GITHUB_REPO="FrameTrain-App"
# Optional: Personal Access Token (only for private repos)
# Leave empty for public repositories
GITHUB_TOKEN=""

# ============================================
# GOOGLE OAUTH (Login)
# ============================================
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="dein-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="dein-google-oauth-client-secret"

# ============================================
# FRAMESPHERE SSO
# ============================================
FRAMESPHERE_URL="https://frame-sphere.vercel.app"
FRAMESPHERE_API_URL="https://framesphere-backend.vercel.app/api"
FRAMESPHERE_CLIENT_ID="frametrain"
FRAMESPHERE_CLIENT_SECRET="dein-framesphere-client-secret"

# ============================================
# RESEND (E-Mail-Verifikation)
# ============================================
# API-Key aus dem Resend-Dashboard: https://resend.com/api-keys
# Voraussetzung: frame-train.com muss dort als Domain verifiziert sein (DNS-Records gesetzt).
RESEND_API_KEY="re_..."
# Absenderadresse – muss auf der bei Resend verifizierten Domain liegen.
EMAIL_FROM="FrameTrain <no-reply@frame-train.com>"

# ============================================
# OPEN LIBRARY ADMIN (Script Verification)
# ============================================
# Beliebiges starkes Passwort – muss in Manager/components.js als FT_ADMIN_TOKEN eingetragen werden
# Generieren z.B. mit: openssl rand -hex 32
LIBRARY_ADMIN_SECRET="dein-geheimes-admin-token"

# Groq API Key für automatische Script-Prüfung
# https://console.groq.com/keys
GROQ_API_KEY="gsk_..."

# ============================================
# SONSTIGE INTEGRATIONEN
# ============================================
# Schützt POST /api/status-updates – nur Codex/CI darf damit Status posten
CODEX_API_KEY="dein-codex-api-key"
# Schützt die Vercel-Cron-Route /api/cron/expire-promo-access
CRON_SECRET="dein-cron-secret"
# WebControl HQ Manager API (Changelog, Support-Tickets im Dashboard)
NEXT_PUBLIC_MANAGER_API_URL="https://webcontrol-hq-api.karol-paschek.workers.dev"

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV="development"
