// Prisma Schema for FrameTrain Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique                  // always required – SSO users always have email
  name              String?
  communityName     String?   @unique @map("community_name") // Eindeutiger Name für Open Library Scripts
  passwordHash      String?   @map("password_hash")
  desktopPasswordHash String? @map("desktop_password_hash") // separates Passwort für Desktop-App (OAuth-User)
  provider          String?                            // "email" | "google" | "github" | "framesphere"
  providerAccountId String?   @map("provider_account_id")
  framesphereUserId String?   @unique @map("framesphere_user_id")
  hasPaid              Boolean   @default(false) @map("has_paid")
  lifetimeAccess       Boolean   @default(false) @map("lifetime_access") // Zugang via Lifetime-Promo-Code — darf nie durch Abo-Events deaktiviert werden
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  subscriptionCancelAt DateTime? @map("subscription_cancel_at")
  termsAcceptedAt      DateTime? @map("terms_accepted_at")            // Zeitpunkt der Zustimmung zu AGB & Datenschutz
  diagnosticsConsent   Boolean   @default(false) @map("diagnostics_consent") // Optionale Einwilligung: Desktop-App darf anonyme Fehlerdaten senden
  diagnosticsConsentAt DateTime? @map("diagnostics_consent_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  apiKeys          ApiKey[]
  models           Model[]
  payments         Payment[]
  libraryScripts   LibraryScript[]
  promoRedemptions PromoCodeRedemption[]

  @@map("users")
}

// Promo-Codes (werden von der Admin-Webseite aus angelegt und verwaltet)
model PromoCode {
  id                    String    @id @default(cuid())
  code                  String    @unique                        // immer normalisiert: GROSSBUCHSTABEN, A-Z 0-9 und "-"
  type                  String                                   // "percent" | "free_months" | "lifetime"
  percentOff            Int?      @map("percent_off")            // 1–100, nur bei type=percent
  percentDuration       String?   @map("percent_duration")       // "once" | "forever" | "repeating" (Stripe-Coupon-Duration)
  percentDurationMonths Int?      @map("percent_duration_months") // nur bei percentDuration=repeating
  freeMonths            Int?      @map("free_months")            // nur bei type=free_months
  maxRedemptions        Int?      @map("max_redemptions")        // null = unbegrenzt einlösbar
  redemptionCount       Int       @default(0) @map("redemption_count")
  expiresAt             DateTime? @map("expires_at")             // null = kein Ablaufdatum
  isActive              Boolean   @default(true) @map("is_active")
  stripeCouponId        String?   @map("stripe_coupon_id")       // wird beim ersten Checkout lazy angelegt (nur type=percent)
  note                  String?                                  // interne Admin-Notiz, wird Usern nie angezeigt
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  redemptions PromoCodeRedemption[]

  @@index([isActive])
  @@map("promo_codes")
}

model PromoCodeRedemption {
  id              String    @id @default(cuid())
  promoCodeId     String    @map("promo_code_id")
  userId          String    @map("user_id")
  status          String    @default("pending")      // "pending" (Checkout gestartet) | "completed" (Checkout abgeschlossen / Lifetime eingelöst)
  plan            String?                            // "monthly" | "yearly" | null (lifetime)
  stripeSessionId String?   @map("stripe_session_id")
  redeemedAt      DateTime  @default(now()) @map("redeemed_at")
  completedAt     DateTime? @map("completed_at")

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])                    // jeder User kann jeden Code nur 1× einlösen
  @@index([userId])
  @@map("promo_code_redemptions")
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  key        String    @unique
  isActive   Boolean   @default(true) @map("is_active")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([userId])
  @@map("api_keys")
}

model Model {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  name        String
  description String?
  status      String    @default("created")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions    ModelVersion[]

  @@index([userId])
  @@map("models")
}

model ModelVersion {
  id          String    @id @default(cuid())
  modelId     String    @map("model_id")
  version     Int
  parameters  String
  metrics     String?
  status      String    @default("pending")
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  model       Model @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, version])
  @@index([modelId])
  @@map("model_versions")
}

model LibraryScript {
  id             String    @id @default(cuid())
  userId         String?   @map("user_id")            // Verknüpfung zum User (Owner des Scripts)
  name           String
  description    String
  author         String                               // Legacy: für Anzeige und historische Daten
  model_type     String    @map("model_type")
  task_type      String    @map("task_type")
  framework      String
  script         String    @db.Text
  script_type    String    @default("train") @map("script_type")
  verified       Boolean   @default(false)
  downloads      Int       @default(0)
  stars          Int       @default(0)
  tags           String[]  @default([])
  aiCheckResult  String?   @db.Text @map("ai_check_result")
  aiCheckedAt    DateTime? @map("ai_checked_at")
  rejectedAt     DateTime? @map("rejected_at")
  rejectedReason String?   @map("rejected_reason")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([verified])
  @@index([model_type])
  @@index([framework])
  @@index([script_type])
  @@index([userId])
  @@map("library_scripts")
}

// Tägliche Status-Updates von Codex (Automatisierung)
model StatusUpdate {
  id          String   @id @default(cuid())
  title       String                           // Kurze Überschrift, z. B. "Synapse Builder: Canvas-Fixes"
  body        String   @db.Text               // Markdown-fähiger Fließtext
  type        String   @default("status")     // "status" | "milestone" | "hotfix" | "dev"
  appVersion  String?  @map("app_version")    // Optional: z. B. "0.9.3-dev"
  source      String?  @map("source")         // Optional: z. B. "desktop-app"
  sourceRef   String?  @map("source_ref")     // Optional: Commit, Tag oder sonstige Referenz
  scope       String?  @map("scope")          // Optional: z. B. "changelog"
  author      String   @default("Codex")      // Wer hat gepostet
  published   Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([published])
  @@index([createdAt])
  @@map("status_updates")
}

model Payment {
  id              String    @id @default(cuid())
  userId          String?   @map("user_id")
  email           String
  amount          Int
  currency        String    @default("eur")
  stripePaymentId      String?   @unique @map("stripe_payment_id")
  stripeSessionId      String?   @unique @map("stripe_session_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  status               String    @default("pending")
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")

  user            User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([userId])
  @@map("payments")
}
